{
  "version": 2,
  "description": "Default input contract for 07_portfolio_risk_model_inputs. Task keys provide input_paths and as_of.",
  "model_id": "portfolio_risk_model",
  "inputs": [
    {
      "role": "option_expression_candidates",
      "data_kind": "option_expression_model_inputs",
      "required": true,
      "notes": "Candidate option expressions before final risk gate"
    },
    {
      "role": "positions",
      "data_kind": "portfolio_position_snapshot",
      "required": false,
      "notes": "Execution/account-owned position state"
    },
    {
      "role": "cash_buying_power",
      "data_kind": "account_snapshot",
      "required": false,
      "notes": "Execution/account-owned account state"
    },
    {
      "role": "open_orders",
      "data_kind": "open_order_snapshot",
      "required": false,
      "notes": "Execution/account-owned order state"
    },
    {
      "role": "risk_limits",
      "data_kind": "risk_limit_config",
      "required": false,
      "notes": "Kill-switch and exposure limits"
    }
  ],
  "storage_target": {
    "id": "trading_data_model_inputs_postgres",
    "driver": "postgresql",
    "secret_alias": "trading_storage_postgres",
    "schema": "model_inputs",
    "create_table": true,
    "batch_size": 5000
  },
  "output": {
    "table": "model_input_artifact_reference",
    "format": "sql_table",
    "natural_key": [
      "run_id",
      "bundle",
      "input_role",
      "data_kind",
      "artifact_reference"
    ],
    "columns": [
      "run_id",
      "task_id",
      "bundle",
      "model_id",
      "as_of",
      "input_role",
      "data_kind",
      "artifact_reference",
      "required",
      "point_in_time",
      "notes",
      "created_at"
    ]
  }
}
