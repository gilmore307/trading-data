{
  "version": 1,
  "description": "Default input contract for security_selection_model_inputs. Task keys provide input_paths and as_of_et.",
  "model_id": "security_selection_model",
  "inputs": [
    {
      "role": "stock_etf_exposure",
      "data_kind": "stock_etf_exposure",
      "required": true,
      "notes": "ETF/sector/theme exposure bridge to candidate stocks"
    },
    {
      "role": "equity_bars",
      "data_kind": "equity_bar",
      "required": true,
      "notes": "Candidate stock and ETF bars"
    },
    {
      "role": "equity_liquidity",
      "data_kind": "equity_liquidity_bar",
      "required": false,
      "notes": "Liquidity filters for candidate tradability"
    },
    {
      "role": "event_exclusions",
      "data_kind": "trading_event",
      "required": false,
      "notes": "Events that exclude or down-rank symbols"
    }
  ]
}
