{
  "version": 2,
  "description": "Default input contract for 04_trade_quality_model_inputs. Task keys provide input_paths and as_of.",
  "model_id": "trade_quality_model",
  "inputs": [
    {
      "role": "strategy_candidates",
      "data_kind": "strategy_selection_model_inputs",
      "required": true,
      "notes": "Candidate strategies/signals emitted by upstream layer"
    },
    {
      "role": "market_context",
      "data_kind": "market_regime_model_inputs",
      "required": true,
      "notes": "Regime context visible at decision time"
    },
    {
      "role": "security_context",
      "data_kind": "security_selection_model_inputs",
      "required": true,
      "notes": "Symbol selection and liquidity context"
    },
    {
      "role": "outcome_labels",
      "data_kind": "trade_quality_label",
      "required": false,
      "notes": "Training-only labels such as MFE/MAE/triple-barrier"
    }
  ],
  "storage_target": {
    "id": "trading_data_model_inputs_postgres",
    "driver": "postgresql",
    "secret_alias": "trading_storage_postgres",
    "schema": "model_inputs",
    "create_table": true,
    "batch_size": 5000
  },
  "output": {
    "table": "model_input_artifact_reference",
    "format": "sql_table",
    "natural_key": [
      "run_id",
      "bundle",
      "input_role",
      "data_kind",
      "artifact_reference"
    ],
    "columns": [
      "run_id",
      "task_id",
      "bundle",
      "model_id",
      "as_of",
      "input_role",
      "data_kind",
      "artifact_reference",
      "required",
      "point_in_time",
      "notes",
      "created_at"
    ]
  }
}
