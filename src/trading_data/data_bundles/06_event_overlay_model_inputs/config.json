{
  "version": 2,
  "description": "Default input contract for 06_event_overlay_model_inputs. Task keys provide input_paths and as_of.",
  "model_id": "event_overlay_model",
  "inputs": [
    {
      "role": "gdelt_articles",
      "data_kind": "gdelt_article",
      "required": false,
      "notes": "Broad news source evidence"
    },
    {
      "role": "sec_company_financials",
      "data_kind": "sec_company_fact",
      "required": false,
      "notes": "Official company/SEC evidence"
    },
    {
      "role": "trading_economics_calendar",
      "data_kind": "trading_economics_calendar_event",
      "required": false,
      "notes": "Accepted macro calendar/value rows"
    },
    {
      "role": "option_activity_events",
      "data_kind": "option_activity_event",
      "required": false,
      "notes": "Option activity event context"
    },
    {
      "role": "equity_abnormal_activity_events",
      "data_kind": "equity_abnormal_activity_event",
      "required": false,
      "notes": "Stock/ETF abnormal market activity context"
    }
  ],
  "storage_target": {
    "id": "trading_data_model_inputs_postgres",
    "driver": "postgresql",
    "secret_alias": "trading_storage_postgres",
    "schema": "model_inputs",
    "create_table": true,
    "batch_size": 5000
  },
  "output": {
    "table": "model_input_artifact_reference",
    "format": "sql_table",
    "natural_key": [
      "run_id",
      "bundle",
      "input_role",
      "data_kind",
      "artifact_reference"
    ],
    "columns": [
      "run_id",
      "task_id",
      "bundle",
      "model_id",
      "as_of",
      "input_role",
      "data_kind",
      "artifact_reference",
      "required",
      "point_in_time",
      "notes",
      "created_at"
    ]
  }
}
