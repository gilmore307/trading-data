{
  "version": 2,
  "description": "MarketRegimeModel ETF bar acquisition contract. Task keys provide start/end; market_etf_universe_path supplies the ETF universe and per-symbol bar grain.",
  "model_id": "market_regime_model",
  "market_etf_universe_path": "/root/projects/trading-main/storage/shared/market_etf_universe.csv",
  "secret_alias": "alpaca",
  "adjustment": "raw",
