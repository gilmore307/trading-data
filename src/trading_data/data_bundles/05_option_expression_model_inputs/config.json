{
  "version": 3,
  "description": "OptionExpressionModel option-chain snapshot input contract. Task keys provide underlying and snapshot_time; final output is a SQL row with nested contracts payload.",
  "model_id": "option_expression_model",
  "storage_target": {
    "id": "trading_data_model_inputs_postgres",
    "driver": "postgresql",
    "secret_alias": "trading_storage_postgres",
    "schema": "model_inputs",
    "create_table": true,
    "batch_size": 5000
  },
  "output": {
    "table": "option_expression_option_chain_snapshot",
    "format": "sql_table",
    "natural_key": ["run_id", "underlying", "snapshot_time"],
    "columns": ["run_id", "task_id", "underlying", "snapshot_time", "contract_count", "contracts"]
  }
}
