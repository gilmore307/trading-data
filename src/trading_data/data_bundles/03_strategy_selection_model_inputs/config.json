{
  "version": 3,
  "description": "StrategySelectionModel symbol bar/liquidity input contract. Task keys provide start/end/symbols; final output is 1Min bar plus liquidity SQL rows by default.",
  "model_id": "strategy_selection_model",
  "secret_alias": "alpaca",
  "default_timeframe": "1Min",
  "adjustment": "raw",
  "limit": 1000,
  "max_pages": 10,
  "timeout_seconds": 20,
  "storage_target": {
    "id": "trading_data_model_inputs_postgres",
    "driver": "postgresql",
    "secret_alias": "trading_storage_postgres",
    "schema": "model_inputs",
    "create_table": true,
    "batch_size": 5000
  },
  "output": {
    "table": "strategy_selection_symbol_bar_liquidity",
    "format": "sql_table",
    "natural_key": ["run_id", "symbol", "timeframe", "timestamp"],
    "columns": ["run_id", "task_id", "symbol", "timeframe", "timestamp", "open", "high", "low", "close", "volume", "vwap", "trade_count", "dollar_volume", "quote_count", "avg_bid", "avg_ask", "avg_bid_size", "avg_ask_size", "avg_spread", "spread_bps", "last_bid", "last_ask"]
  }
}
